APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
TELESCOPE_ENABLED=

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL (recomendado). Criação automática: composer run db:setup (ou php artisan db:create)
# Manual: docs/database/postgresql-setup.md
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=mm_sports
DB_USERNAME=postgres
DB_PASSWORD=

# Credenciais com permissão CREATEDB (superuser). Usadas só por: php artisan db:create
# Se vazio, usam DB_USERNAME / DB_PASSWORD (precisa poder criar o banco).
DB_ROOT_USER=
DB_ROOT_PASSWORD=
# Conexão bootstrap antes do CREATE (padrão postgres)
# DB_BOOTSTRAP_DATABASE=postgres

# Full-text search: use "auto" com PostgreSQL (pg_trgm) — ver config/fts.php
FTS_DRIVER=auto

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

#START CONFIG CODIFYTECH
CDF_API_VERSION=
CDF_DIR_FRONT_END=
CDF_FRONT_END_URL=
CDF_DELETE_PREVIOUS_ACCESS_TOKENS_ON_LOGIN=
CDF_DEFAULT_ROLE_SLUG=
CDF_EMAIL_VERIFICATION=

JWT_SECRET=
JWT_TTL=
#END CONFIG CODIFYTECH

MM_STORE_POSTAL_CODE=
ASAAS_API_KEY=
ASAAS_BASE_URL=
ASAAS_WEBHOOK_TOKEN=
CORREIOS_USERNAME=
CORREIOS_POSTING_CARD=
