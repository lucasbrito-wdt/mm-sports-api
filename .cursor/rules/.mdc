### Error Handling (OBRIGATÓRIO)
```php
// Sempre usar try-catch para operações críticas
try {
    $result = $this->generator->generate($config);
    $this->rollbackLogger->logSuccess($result);
} catch (GeneratorException $e) {
    $this->rollbackLogger->logError($e);
    $this->error("Falha na geração: " . $e->getMessage());
    return CommandAlias::FAILURE;
} catch (ValidationException $e) {
    $this->warn("Validação falhou: " . $e->getMessage());
    return CommandAlias::INVALID;
}

// Logging estruturado
Log::info('Geração iniciada', [
    'domain' => $config['domain'],
    'model' => $config['model'],
    'user' => auth()->user()?->id,
    'session_id' => $sessionId
]);
```

### Validation (OBRIGATÓRIA)
```php
// Sempre validar inputs
private function validateConfig(array $config): ValidationResult
{
    $validator = Validator::make($config, [
        'domain' => 'required|string|alpha',
        'model' => 'required|string|alpha',
        'schema' => 'required|string',
        'foreign_keys' => 'array',
        'foreign_keys.*.model' => 'required_with:foreign_keys|string|alpha',
        'foreign_keys.*.domain' => 'required_with:foreign_keys|string|alpha',
        'foreign_keys.*.relation' => 'required_with:foreign_keys|in:belongsTo,hasMany,hasOne,belongsToMany'
    ]);

    return $validator->fails()
        ? ValidationResult::failed($validator->errors())
        : ValidationResult::success();
}

// Sanitizar paths
private function sanitizePath(string $path): string
{
    // Remover path traversal
    $path = str_replace(['../', '..\\'], '', $path);

    // Validar contra whitelist
    if (!preg_match('/^[a-zA-Z0-9\/_-]+$/', $path)) {
        throw new InvalidPathException("Path inválido: {$path}");
    }

    return $path;
}
```

